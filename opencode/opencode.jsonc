{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-beads@0.4.0"
  ],
  "model": "openai/gpt-5.4",
  "default_agent": "captain",
  "autoupdate": false,
  "permission": {
    "external_directory": {
      "/var/folders/**": "allow",
      "/private/var/folders/**": "allow",
      "/Users/shaunmcquaker/Documents/Logseq/**": "allow",
      "/Users/shaunmcquaker/Documents/Work/**": "allow"
    }
  },
  "lsp": {
    "lua-ls": {
      "disabled": true
    }
  },
  "mcp": {
    "alphaxiv-mcp": {
      "type": "remote",
      "url": "https://api.alphaxiv.org/mcp/v1"
    },
    "anydb-mcp": {
      "type": "local",
      "command": ["npx", "-y", "anydb-mcp"]
    },
    "dsv-mcp": {
      "type": "local",
      "command": [
        "/Users/shaunmcquaker/code/shaun-mcquaker-agents/bin/mcp-remote-header-proxy",
        "dsv-mcp",
        "https://mcp.dailysearchvolume.com/mcp"
      ],
      "timeout": 60000
    },
    "shaun-mcp": {
      "type": "local",
      "command": [
        "/Users/shaunmcquaker/code/shaun-mcquaker-agents/bin/mcp-remote-header-proxy",
        "shaun-mcp",
        "https://mcp.portfolioai.com/mcp"
      ],
      "timeout": 60000
    }
  }
}
