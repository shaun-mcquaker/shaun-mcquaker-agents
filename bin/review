#!/usr/bin/env zsh

set -euo pipefail

layout_file="$HOME/.config/zellij/layouts/dev-session.zsh"

if [[ ! -f "$layout_file" ]]; then
  echo "review: missing $layout_file" >&2
  exit 1
fi

source "$layout_file"

if ! typeset -f review >/dev/null 2>&1; then
  echo "review: function not available after sourcing $layout_file" >&2
  exit 1
fi

review "$@"
