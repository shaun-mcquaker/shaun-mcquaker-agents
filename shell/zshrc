# For the slugs used in the url_capture Cloud Run service
url_slug() {
  local url="$1"
  local pathname=$(echo "$url" | sed -E 's|^https?://[^/]+(/.*)?$|\1|' | sed 's|^/$|/home|')
  local prefix=$(echo "$pathname" | sed 's|^/||' | sed 's|/|-|g' | cut -c1-10)
  local hash=$(echo -n "$url" | openssl dgst -md5 -binary | openssl base64 -A | tr '+/' '-_' | tr -d '=')
  echo "${prefix}-${hash}"
}

