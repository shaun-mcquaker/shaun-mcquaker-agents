# Optional local editor backup helpers.
backup_ide() {
  local binary_name="$1"
  local settings_folder="$2"

  if [[ -z "$binary_name" || -z "$settings_folder" ]]; then
    echo "Usage: backup_ide <binary_name> <settings_folder>"
    return 1
  fi

  local editor_key="${binary_name:l}"
  local backup_dir="$HOME/backups/$(date '+%Y-%m-%d')"
  local backup_file="$backup_dir/${editor_key}.tar.gz"

  # Skip if already backed up today
  [[ -f "$backup_file" ]] && return 0

  mkdir -p "$backup_dir"
  local temp_dir=$(mktemp -d)
  local user_dir="$HOME/Library/Application Support/$settings_folder/User"

  # Copy only essential config files
  [[ -f "$user_dir/settings.json" ]] && cp "$user_dir/settings.json" "$temp_dir/"
  [[ -f "$user_dir/keybindings.json" ]] && cp "$user_dir/keybindings.json" "$temp_dir/"
  [[ -d "$user_dir/snippets" ]] && cp -r "$user_dir/snippets" "$temp_dir/"

  # Export extensions list and fail loudly if it cannot be captured.
  if ! command -v "$binary_name" >/dev/null 2>&1; then
    echo "Error: editor binary '$binary_name' not found in PATH; cannot back up extensions." >&2
    rm -rf "$temp_dir"
    return 1
  fi

  if ! "$binary_name" --list-extensions > "$temp_dir/extensions.txt" 2>/dev/null; then
    echo "Error: failed to run '$binary_name --list-extensions'." >&2
    rm -rf "$temp_dir"
    return 1
  fi

  if ! grep -q '[^[:space:]]' "$temp_dir/extensions.txt"; then
    echo "Error: '$binary_name --list-extensions' returned no extensions; aborting backup." >&2
    rm -rf "$temp_dir"
    return 1
  fi

  # Create archive and always clean temp files
  if ! tar -czf "$backup_file" -C "$temp_dir" .; then
    echo "Error: failed to create backup archive at '$backup_file'." >&2
    rm -rf "$temp_dir"
    return 1
  fi
  rm -rf "$temp_dir"

  # Clean backups older than 120 days
  find "$HOME/backups" -name "${editor_key}.tar.gz" -mtime +120 -delete 2>/dev/null || true
}

restore_ide() {
  local binary_name="$1"
  local settings_folder="$2"
  local date="${3:-$(date '+%Y-%m-%d')}"

  if [[ -z "$binary_name" || -z "$settings_folder" ]]; then
    echo "Usage: restore_ide <binary_name> <settings_folder> [date: YYYY-MM-DD]"
    return 1
  fi

  local editor_key="${binary_name:l}"
  local backup_file="$HOME/backups/$date/${editor_key}.tar.gz"
  local restore_dir="${TMPDIR:-/tmp}/${editor_key}-restore-$date"
  local target_user_dir="$HOME/Library/Application Support/$settings_folder/User"

  if [[ ! -f "$backup_file" ]]; then
    echo "Backup not found: $backup_file"
    return 1
  fi

  rm -rf "$restore_dir"
  mkdir -p "$restore_dir"
  tar -xzf "$backup_file" -C "$restore_dir"

  echo "Restored to: $restore_dir"
  echo "Extensions list: $restore_dir/extensions.txt"
  echo "Target settings folder: $target_user_dir"
}

# Auto-backup on shell start (once per editor per day)
command -v cursor >/dev/null 2>&1 && backup_ide cursor Cursor
command -v code >/dev/null 2>&1 && backup_ide code Code

